# Database (satu-satunya backing service)
DATABASE_URL=postgresql://user:password@localhost:5432/atiga_db

# Auth
JWT_SECRET=replace-with-32-characters-minimum-secret-key
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Backend
BACKEND_PORT=3100
NODE_ENV=development
FRONTEND_URL=http://localhost:3001
FRONTEND_PORT=3001

# AI Provider
AI_DEFAULT_PROVIDER=anthropic
# Ganti AI_DEFAULT_PROVIDER=deepseek jika ingin pakai DeepSeek sebagai default
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
GOOGLE_API_KEY=
GOOGLE_MODEL=gemini-1.5-pro
# DeepSeek
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat

# Storage
STORAGE_DRIVER=local
STORAGE_LOCAL_PATH=./uploads
STORAGE_PUBLIC_BASE_URL=http://localhost:3100

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:3100
